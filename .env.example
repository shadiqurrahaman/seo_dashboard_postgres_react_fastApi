# PostgreSQL
POSTGRES_DB=growmos
POSTGRES_USER=growmos
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://growmos:changeme@postgres:5432/growmos

# JWT
SECRET_KEY=replace-with-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth (for Sign-in + BigQuery)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_BQ_REDIRECT_URI=http://localhost:8000/datasources/bigquery/callback

# CORS
FRONTEND_URL=http://localhost:5173

# File storage
UPLOAD_DIR=/app/uploads
